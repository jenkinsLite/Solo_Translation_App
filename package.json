{
  "name": "Solo_Translation_App",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "npm install --production=false && vite build && cd server && npm install",
    "dev-start-server": "cd server && nodemon -e js,html,css --env-file=.env server.js",
    "dev-start-client": "npm run build && vite",
    "dev": "concurrently \"npm run dev-start-server\" \"npm run dev-start-client\"",
    "prod-l": "cd server && node --env-file=.env server.js",
    "prod": "cd server && node server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^8.0.1"
  }
}
